# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Public contact address (shown on site)
CONTACT_EMAIL=contact@dailyops.tech

# Inbox that actually receives form/chat/newsletter notifications.
# Use your real mailbox until contact@dailyops.tech is configured to receive mail.
NOTIFY_EMAIL=stevebaa6@gmail.com

# Verified sending subdomain in Resend (news.dailyops.tech)
RESEND_DOMAIN=news.dailyops.tech
RESEND_FROM_EMAIL=DailyOps <noreply@news.dailyops.tech>

# Optional: Resend Segment for newsletter list (Audiences → Segments in dashboard)
# Subscribers are always saved in Resend → Contacts; segment groups them for broadcasts.
# RESEND_SEGMENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Legacy alias (still supported):
# RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Ko-fi — support page (defaults to https://ko-fi.com/dailyops)
# NEXT_PUBLIC_KOFI_URL=https://ko-fi.com/dailyops

# Optional: Ko-fi API key (server-side only — donation stats/webhooks, not needed for the public link)
# KOFI_API_KEY=your_kofi_api_key

# Chat assistant — AI model (optional; keyword fallback works without)
# OpenAI: OPENAI_API_KEY=sk-...
# xAI Grok: XAI_API_KEY=xai-... + OPENAI_BASE_URL=https://api.x.ai/v1 + CHAT_MODEL=grok-3-mini
# OPENAI_API_KEY=sk-...
# XAI_API_KEY=xai-...
# CHAT_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Chat assistant — web search for Tier 4 (CVE, news, versions) and Tier 2 vendor docs
# Use ONE of these (Tavily preferred):
# TAVILY_API_KEY=tvly-...   — https://tavily.com
# SERPER_API_KEY=...        — https://serper.dev