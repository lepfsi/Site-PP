# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Recipient for contact form + newsletter notifications
CONTACT_EMAIL=contact@dailyops.tech

# Sender (verify dailyops.tech domain in Resend first)
# RESEND_FROM_EMAIL=DailyOps <noreply@dailyops.tech>
# Until domain is verified, Resend allows: DailyOps <onboarding@resend.dev>

# Optional: Resend Audience ID for newsletter subscriber list
# Create an Audience in Resend dashboard → copy ID
# RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Ko-fi — support page (defaults to https://ko-fi.com/dailyops)
# NEXT_PUBLIC_KOFI_URL=https://ko-fi.com/dailyops

# Optional: Ko-fi API key (server-side only — donation stats/webhooks, not needed for the public link)
# KOFI_API_KEY=your_kofi_api_key

# Chat assistant (optional — fallback mode works without AI)
# OPENAI_API_KEY=sk-...
# CHAT_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1